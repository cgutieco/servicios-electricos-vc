---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Heading from './ui/Heading.astro';

interface Props {
  title: string;
  imageSrc: ImageMetadata;
  imageAlt: string;
}

const { title, imageSrc, imageAlt } = Astro.props;
---

<div class="bg-white rounded-lg border border-outline-variant shadow-sm flex flex-col">
  <Picture 
    src={imageSrc} 
    alt={imageAlt} 
    widths={[300, 600]}
    sizes="300px"
    formats={['avif', 'webp']}
    fallbackFormat="webp"
    class="w-full h-48 object-cover" 
  />
  <div class="p-sm bg-cloud-gray grow">
    <Heading level={3} class="mb-xs">{title}</Heading>
  </div>
</div>
