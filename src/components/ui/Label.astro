---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'label'> {}

const { class: className, ...rest } = Astro.props;
---

<label
  class:list={[
    "font-label-md text-label-md text-on-surface-variant block mb-base",
    className
  ]}
  {...rest}
>
  <slot />
</label>
