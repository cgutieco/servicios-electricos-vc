---
import type { HTMLAttributes } from 'astro/types';

type ButtonProps = HTMLAttributes<'button'>;
type AnchorProps = HTMLAttributes<'a'>;

interface Props extends Omit<ButtonProps, keyof AnchorProps>, AnchorProps {
  variant?: 'primary' | 'whatsapp' | 'close';
  href?: string;
}

const { variant = 'primary', href, class: className, ...rest } = Astro.props;

const baseStyles = "cursor-pointer disabled:cursor-not-allowed disabled:opacity-50 disabled:active:scale-100 font-button text-button rounded-lg active:scale-95 transition-all duration-200 flex items-center justify-center";

const variants = {
  primary: "bg-industrial-orange text-white py-sm px-md",
  whatsapp: "bg-[#25D366] text-white py-sm px-md hover:bg-[#20b858]",
  close: "absolute top-sm right-sm text-on-surface-variant hover:text-dark-navy transition-colors p-xs active:scale-100"
};

const combinedClass = [
  variant !== 'close' ? baseStyles : '',
  variants[variant],
  className
].filter(Boolean).join(' ');
---

{
  href ? (
    <a href={href} class={combinedClass} {...rest as HTMLAttributes<'a'>}>
      <slot />
    </a>
  ) : (
    <button class={combinedClass} {...rest as HTMLAttributes<'button'>}>
      <slot />
    </button>
  )
}
