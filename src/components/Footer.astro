---
import iconFooter from '../assets/icons/servicios-electricos-vc-icon-footer.svg';
import FooterLink from './FooterLink.astro';

const socialLinks = [
  {
    name: 'Facebook',
    href: 'https://www.facebook.com/profile.php?id=100063547481558&locale=es_LA',
    ariaLabel: 'Facebook de Servicios Eléctricos VC',
    icon: 'facebook',
  },
  {
    name: 'WhatsApp',
    href: 'https://wa.me/51987178258',
    ariaLabel: 'WhatsApp de Servicios Eléctricos VC',
    icon: 'whatsapp',
  },
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/in/victor-alberto-campos-cisneros-53385353/?lipi=urn%3Ali%3Apage%3Ad_flagship3_profile_view_base_contact_details%3BsaY%2FQpcHQEy3C3fl8AKBnw%3D%3D',
    ariaLabel: 'LinkedIn de Víctor Alberto Campos Cisneros',
    icon: 'linkedin',
  },
];
---
<footer class="bg-linear-to-b from-dark-navy to-[#152d4a] text-[#c8d6e5]">
    <div class="pt-lg pb-8">
        <div class="responsive-container grid grid-cols-1 gap-8 md:grid-cols-[1.4fr_1fr_1fr] md:gap-lg">

            <!-- Columna 1: Marca -->
            <div class="flex flex-col">
                <div class="flex items-center gap-3 mb-3">
                    <img src={iconFooter.src} width={iconFooter.width} height={iconFooter.height} alt="Servicios Eléctricos VC"/>
                    <span class="font-h3 text-[18px] font-bold text-white tracking-[0.02em]">SERVICIOS ELÉCTRICOS VC</span>
                </div>
                <p class="font-body-md text-[14px] leading-[1.6] text-[#8fa3b8] mb-xs max-w-70">
                    Mantenimiento electromecánico confiable para condominios.
                </p>
                <p class="font-body-md text-[13px] text-[#6b82a0] tracking-[0.03em]">RUC: 10066311568</p>
            </div>

            <!-- Columna 2: Contacto (anti-scraping con decodificación progresiva) -->
            <div>
                <h3 class="footer-title">
                    Contacto
                </h3>
                <ul class="list-none p-0 m-0 flex flex-col gap-3">
                    <li class="flex items-center">
                        <FooterLink
                            href="#"
                            class="js-contact-link"
                            data-type="email"
                            data-value="dmljdG9yY2FtcG9zMzhAaG90bWFpbC5jb20="
                            aria-label="Enviar correo electrónico"
                        >
                            <svg class="shrink-0 text-industrial-orange transition-colors duration-250" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
                                <rect width="20" height="16" x="2" y="4" rx="2"/>
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                            <span>Correo electrónico</span>
                        </FooterLink>
                    </li>
                    <li class="flex items-center">
                        <FooterLink
                            href="#"
                            class="js-contact-link"
                            data-type="phone"
                            data-value="OTg3MTc4MjU4"
                            aria-label="Llamar por teléfono"
                        >
                            <svg class="shrink-0 text-industrial-orange transition-colors duration-250" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                            <span>Llamar ahora</span>
                        </FooterLink>
                    </li>
                </ul>
                <noscript>
                    <p class="font-body-md text-[13px] text-[#8fa3b8] mt-3">Habilita JavaScript para ver la información de contacto.</p>
                </noscript>
            </div>

            <!-- Columna 3: Redes y Enlaces -->
            <div>
                <h3 class="footer-title">
                    Síguenos
                </h3>
                <div class="flex flex-col gap-3">
                    {socialLinks.map((link) => (
                        <FooterLink
                            href={link.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={link.ariaLabel}
                        >
                            {link.icon === 'facebook' && (
                                <svg class="shrink-0 text-industrial-orange transition-colors duration-250"
                                     viewBox="0 0 24 24" fill="currentColor" width="22" height="22"
                                     xmlns="http://www.w3.org/2000/svg">
                                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                                </svg>
                            )}
                            {link.icon === 'whatsapp' && (
                                <svg class="shrink-0 text-industrial-orange transition-colors duration-250"
                                     fill="currentColor" height="22" viewBox="0 0 24 24" width="22"
                                     xmlns="http://www.w3.org/2000/svg">
                                    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"></path>
                                </svg>
                            )}
                            {link.icon === 'linkedin' && (
                                <svg class="shrink-0 text-industrial-orange transition-colors duration-250"
                                     fill="currentColor" height="22" viewBox="0 0 24 24" width="22"
                                     xmlns="http://www.w3.org/2000/svg">
                                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                                </svg>
                            )}
                            <span>{link.name}</span>
                        </FooterLink>
                    ))}
                </div>
            </div>
        </div>
    </div>

    <!-- Barra inferior -->
    <div class="border-t border-white/8 py-[20px]">
        <div class="responsive-container flex flex-col items-center gap-[8px] text-center md:flex-row md:justify-between md:text-left">
            <p class="font-body-md text-[13px] text-[#6b82a0]">© {new Date().getFullYear()} Servicios Eléctricos VC.
                Todos los derechos reservados.</p>
            <p class="font-body-md text-[13px] text-[#6b82a0]">
                Desarrollado por
                {" "}
                <a
                        href="https://www.linkedin.com/in/cesar-gutierrez-contreras"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-primary-fixed-dim no-underline font-semibold transition-colors duration-200 hover:text-white hover:underline"
                >@cgutieco</a>
            </p>
        </div>
    </div>
</footer>

<style>
    .footer-title {
        font-family: var(--font-h3),sans-serif;
        font-size: 14px;
        font-weight: 600;
        color: white;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: var(--spacing-sm);
        position: relative;
        padding-bottom: 10px;
    }
    .footer-title::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 28px;
        height: 2px;
        background-color: var(--color-industrial-orange);
        border-radius: 1px;
    }
</style>

<script>
    function initFooterContact(): void {
        const contactLinks = document.querySelectorAll<HTMLAnchorElement>('.js-contact-link');
        contactLinks.forEach(link => {
            const type = link.getAttribute('data-type');
            const encodedValue = link.getAttribute('data-value');
            if (!type || !encodedValue) return;

            const decoded = atob(encodedValue);
            if (type === 'email') {
                link.href = `mailto:${decoded}`;
            } else if (type === 'phone') {
                link.href = `tel:+51${decoded}`;
            }

            link.classList.remove('js-contact-link');
            link.removeAttribute('data-type');
            link.removeAttribute('data-value');
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFooterContact);
    } else {
        initFooterContact();
    }
</script>
