---
import Heading from './ui/Heading.astro';
import Button from './ui/Button.astro';
import Input from './ui/Input.astro';
import Textarea from './ui/Textarea.astro';
import Label from './ui/Label.astro';

const SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '1x00000000000000000000AA';
---
<section class="bg-cloud-gray py-lg md:py-xl border-b border-outline-variant">
  <div class="responsive-container">
    <div class="max-w-128 mx-auto">
    <Heading level={2} class="mb-md text-center">
      Solicita una evaluación para tu condominio
    </Heading>
    <form class="js-contact-form flex flex-col gap-sm">
      <div>
        <Label for="contact-name">Nombre (Opcional)</Label>
        <Input id="contact-name" name="name" placeholder="Tu nombre" type="text" />
      </div>
      <div>
        <Label for="contact-condominio">Condominio (Opcional)</Label>
        <Input id="contact-condominio" name="condominio" placeholder="Nombre de tu condominio" type="text" />
      </div>
      <div>
        <Label for="contact-phone">Teléfono (Obligatorio)</Label>
        <Input id="contact-phone" name="phone" placeholder="Tu número" type="tel" required />
      </div>
      <div>
        <Label for="contact-service">Servicio Requerido (Obligatorio)</Label>
        <Textarea id="contact-service" name="service" placeholder="Describe el servicio que necesitas..." required></Textarea>
      </div>

      <!-- Turnstile CAPTCHA Widget -->
      <div class="flex justify-center my-xs">
        <div class="cf-turnstile animate-fade-in" data-sitekey={SITE_KEY} data-theme="light"></div>
      </div>

      <!-- Response feedback container -->
      <div class="js-contact-feedback hidden p-xs rounded font-body-md text-center my-xs transition-all duration-200"></div>

      <Button class="w-full mt-xs" type="submit" disabled>
        Enviar Solicitud
      </Button>
    </form>
  </div>
  </div>
</section>
