---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'a'> {
  href: string;
}

const { href, class: className, ...rest } = Astro.props;
---
<a
  href={href}
  class:list={[
    "inline-flex items-center gap-2.5 text-[#8fa3b8] no-underline font-body-md text-[14px] py-[8px] px-3.5 rounded-lg transition-all duration-250 bg-white/4 border border-white/6 hover:text-white hover:bg-white/10 hover:border-white/15 hover:translate-x-[4px]",
    className
  ]}
  {...rest}
>
  <slot />
</a>
