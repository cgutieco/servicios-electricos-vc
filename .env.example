# Resend API Configuration
RESEND_API_KEY=re_your_api_key_here

# Cloudflare Turnstile Configuration
# Public site key (exposed to client - must start with PUBLIC_ in Astro)
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAA...
# Private secret key (kept secure on server)
TURNSTILE_SECRET_KEY=0x4AAAAAA...

# Optional: Email configurations
SENDER_EMAIL=contacto@cgutieco.com
RECIPIENT_EMAIL=contacto@cgutieco.com
